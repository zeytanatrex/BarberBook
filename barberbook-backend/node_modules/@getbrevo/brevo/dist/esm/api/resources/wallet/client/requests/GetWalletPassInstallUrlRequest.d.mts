/**
 * @example
 *     {
 *         passId: "passId",
 *         contactId: 1000000
 *     }
 */
export interface GetWalletPassInstallUrlRequest {
    /** Pass ID. The unique identifier of the wallet pass for which to generate an installation URL. */
    passId: string;
    /** The Brevo contact ID the installation URL is generated for. */
    contactId: number;
}
